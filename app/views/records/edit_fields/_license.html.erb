<% license_service = Hyrax.config.license_service_class.new %>
<% if f.object.multiple? :license %>
  <%= f.input :license, as: :multi_value_select,
      collection: license_service.select_active_options,
      include_blank: true,
      item_helper: license_service.method(:include_current_value),
      input_html: { class: 'form-control' } %>
<% else %>
  <% base_options = license_service.select_active_options %>
  <% current_values = Array.wrap(f.object[:license]).select(&:present?) %>
  <% augmented_options = current_values.reduce(base_options) do |opts, value|
       license_service.include_current_value(value, nil, opts, { class: [] }).first
     end %>
  <%= f.input :license, as: :select,
      collection: augmented_options,
      include_blank: true,
      input_html: { class: 'form-control' } %>
<% end %>
