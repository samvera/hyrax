<% rights_statements = Hyrax.config.rights_statement_service_class.new %>
<% if f.object.multiple? :rights_statement %>
  <%= f.input :rights_statement, as: :multi_value_select,
      collection: rights_statements.select_active_options,
      include_blank: true,
      item_helper: rights_statements.method(:include_current_value),
      input_html: { class: 'form-control' } %>
<% else %>
  <% base_options = rights_statements.select_active_options %>
  <% current_values = Array.wrap(f.object[:rights_statement]).select(&:present?) %>
  <% augmented_options = current_values.reduce(base_options) do |opts, value|
       rights_statements.include_current_value(value, nil, opts, { class: [] }).first
     end %>
  <%= f.input :rights_statement, as: :select,
      collection: augmented_options,
      include_blank: true,
      input_html: { class: 'form-control' } %>
<% end %>
